# Copy this file to .env and fill values before running docker-compose
APP_SECRET=replace_with_a_long_random_secret_of_at_least_32_bytes
STORAGE_BACKEND=supabase  # supabase, local, s3 or cloudinary
# If using Postgres via docker-compose, set DATABASE_URL to the connection string
DATABASE_URL=postgresql://faceapp:changeme@db:5432/faceapp

# Supabase
SUPABASE_URL=
# Use the SERVICE ROLE KEY for server-side uploads
SUPABASE_SERVICE_ROLE_KEY=

# AWS (if STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# Cloudinary (if using cloudinary backend)
CLOUDINARY_URL=

# Admin user (create at first run or via migration)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme